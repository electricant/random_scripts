#!/usr/bin/env bash
#
# Convert all *.mp3 files in the directory to high-quality Opus.
# Only transcodes if source bitrate is higher than target.
# Uses 160 kbps, which is more than transparent for most music. Increase if needed.
#
# Frame Duration (ms) | Typical Use Case
#     2.5, 5, 10      | Ultra-low latency (e.g., VoIP, gaming)
#     20,Default      | balanced for most uses and for maximum compatibility
#     40, 60          | High-quality offline encoding (e.g., music, podcasts)
#
set -e

TARGET_BITRATE=192  # kbps

for a in ./*.mp3; do
	[ -e "$a" ] || continue  # Skip if no mp3 files exist
	
	# Get bitrate using ffprobe (returns in bits/sec)
	BITRATE=$(ffprobe -v error -select_streams a:0 -show_entries stream=bit_rate -of default=noprint_wrappers=1:nokey=1 "$a")
	
	# Convert to kbps
	BITRATE_KBPS=$((BITRATE / 1000))
	
	if [ "$BITRATE_KBPS" -gt "$TARGET_BITRATE" ]; then
		echo "Transcoding $a (bitrate ${BITRATE_KBPS} > ${TARGET_BITRATE})"
		ffmpeg -loglevel warning -stats -i "$a" -c:a libopus \
			-b:a "${TARGET_BITRATE}k" -frame_duration 40 \
			"${a[@]/%mp3/opus}"
		rm "$a"
	else
		echo "Skipping $a (bitrate ${BITRATE_KBPS} <= ${TARGET_BITRATE})"
	fi
done
